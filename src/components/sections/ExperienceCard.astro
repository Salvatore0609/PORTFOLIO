---
import Card from '../Card.astro'
import { Button } from '../ui/button'
import { EXPERIENCE } from '../../lib/constants'
import { useTranslations } from '../../i18n/utils';

const { lang = 'it' } = Astro.locals as { lang?: 'it' | 'en' };
const t = useTranslations(lang);
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2" title={t('experience.title') as string}>
  <div class="mt-2 space-y-4">
    {
      EXPERIENCE.slice(0, 3).map((exp) => (
        <div>
          <h3 class="text-lg font-semibold">{exp.position}</h3>
          <a class="text-sm text-primary" href="#">
            {exp.company}
          </a>
          <p class="text-sm text-gray-600">
            {exp.start} - {exp.end}
          </p>
        </div>
      ))
    }
    <a href="/work">
      <Button variant="link" className="pl-0"> {t('experience.view_more')} </Button>
    </a>
  </div>
</Card>