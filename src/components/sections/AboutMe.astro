---
import Card from '../Card.astro'
import { useTranslations } from '../../i18n/utils';

const lang = (Astro.locals as any).lang || 'it';
const t = useTranslations(lang);
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-6" title={(() => { const title = t('skills.title'); return typeof title === 'string' ? title : Array.isArray(title) ? title.join(' ') : ''; })()}>
  <div class="flex flex-col gap-2">
    <p class="text-sm font-light">
      {t('skills.primary_tools')}
      <ul class="list-inside list-disc text-xs">
        {(() => { const list = t('skills.list'); return Array.isArray(list) && list.map((item: string) => <li>{item}</li>); })()}
      </ul>
    </p>
    <p class="text-sm font-light">
      {t('skills.passion')}
    </p>
  </div>
</Card>