---
import { File } from 'lucide-react'
import Card from '../Card.astro'
import { Button } from '../ui/button'
import { useTranslations } from '../../i18n/utils';

const { lang = 'it' } = Astro.locals as { lang?: 'it' | 'en' };
const t = useTranslations(lang);
const PDF = lang === 'en' ? '/CV_SALVATOREDESOLE_EN.pdf' : '/CV_SALVATOREDESOLE.pdf'
const cvTitle = t('cv.title') as string;
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-4" title={cvTitle}>
  <div class="mt-4 flex w-full justify-center">
    <div class="card card-compact md:w-112 lg:w-128 w-96 gap-2 border-[oklch(var(--p))] transition-all">
      <figure>
        <object data={PDF} type="application/pdf" width="100%"></object>
      </figure>
      <div class="mt-4 flex flex-col gap-2">
        <p class="text-sm text-muted-foreground">
          {t('cv.description')}
        </p>
        <div class="card-actions mt-2 flex w-full items-center justify-center">
          <a target="_blank" href={PDF}>
            <Button>
              {t('cv.button')}
              <File />
            </Button>
          </a>
        </div>
      </div>
    </div>
  </div>
</Card>